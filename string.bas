5 REM ==== TESTE DE STRINGS ====
10 REM --- 1) atribuicao e print ---
20 A$ = "OLA"
30 B$ = "MUNDO"
40 PRINT "TESTE 1: ATRIBUICAO/PRINT"
50 PRINT A$
60 PRINT B$
70 PRINT "ESPERADO: OLA / MUNDO"
80 PRINT ""

100 REM --- 2) concatenacao ---
110 C$ = A$ + " " + B$
120 PRINT "TESTE 2: CONCATENACAO"
130 PRINT C$
140 PRINT "ESPERADO: OLA MUNDO"
150 PRINT ""

200 REM --- 3) comparacao ---
210 PRINT "TESTE 3: COMPARACAO"
220 IF A$ = "OLA" PRINT "A$=OLA -> OK"
230 IF A$ <> "TCHAU" PRINT "A$<>TCHAU -> OK"
240 D$ = "ABC"
250 E$ = "ABD"
260 IF D$ < E$ PRINT "ABC < ABD -> OK"
270 IF E$ > D$ PRINT "ABD > ABC -> OK"
280 IF D$ <= D$ PRINT "ABC <= ABC -> OK"
290 IF D$ >= D$ PRINT "ABC >= ABC -> OK"
300 PRINT ""

310 REM --- 4) LEFT$/RIGHT$/MID$/LEN ---
320 F$ = "PROGRAMACAO"
330 PRINT "TESTE 4: LEFT$/RIGHT$/MID$/LEN"
340 PRINT "STRING: " + F$
360 PRINT LEN(F$)
370 PRINT "ESPERADO LEN: 11"
380 PRINT "LEFT$ 4: " + LEFT$(F$,4)
390 PRINT "ESPERADO: PROG"
400 PRINT "RIGHT$ 3: " + RIGHT$(F$,3)
410 PRINT "ESPERADO: CAO"
420 PRINT "MID$ 4,4: " + MID$(F$,4,4)
430 PRINT "ESPERADO: GRAM"
440 PRINT "MID$ 8: " + MID$(F$,8)
450 PRINT "ESPERADO: ACAO"
460 PRINT ""

500 REM --- 5) aninhamento de funcoes ---
510 PRINT "TESTE 5: ANINHAMENTO"
520 G$ = LEFT$(MID$(F$,1,7),3)
530 PRINT G$
540 PRINT "ESPERADO: PRO"
550 PRINT ""

600 REM --- 6) STR$/VAL/CHR$/ASC ---
610 PRINT "TESTE 6: STR$/VAL/CHR$/ASC"
620 H$ = STR$(42)
630 PRINT "STR$(42) = " + H$
640 PRINT "ESPERADO: 42"
650 I = VAL("123")
670 PRINT I
680 PRINT "ESPERADO VAL: 123"
690 J$ = CHR$(65)
700 PRINT "CHR$(65) = " + J$
710 PRINT "ESPERADO: A"
720 K = ASC("A")
740 PRINT K
750 PRINT "ESPERADO ASC: 65"
760 PRINT ""

800 REM --- 7) STR$/VAL ida e volta ---
810 PRINT "TESTE 7: STR$/VAL IDA E VOLTA"
820 L = 777
830 M$ = STR$(L)
840 N = VAL(M$)
850 PRINT N
860 PRINT "ESPERADO: 777"
870 PRINT ""

900 REM --- 8) string vazia ---
910 PRINT "TESTE 8: STRING VAZIA"
920 O$ = ""
940 PRINT LEN(O$)
950 PRINT "ESPERADO: 0"
960 P$ = O$ + "X"
970 PRINT P$
980 PRINT "ESPERADO: X"
990 PRINT ""

1000 REM --- 9) string dentro de FOR ---
1010 PRINT "TESTE 9: FOR COM STRING"
1020 Q$ = ""
1030 FOR R = 1 TO 5
1040 Q$ = Q$ + STR$(R)
1050 NEXT R
1060 PRINT Q$
1070 PRINT "ESPERADO: 12345"
1080 PRINT ""

1200 REM --- 10) GOSUB com string global ---
1210 PRINT "TESTE 10: GOSUB COM STRING"
1220 T$ = "ANTES"
1230 GOSUB 1300
1240 PRINT T$
1250 PRINT "ESPERADO: DEPOIS"
1260 PRINT ""
1270 GOTO 1500

1300 T$ = "DEPOIS"
1310 RETURN

1500 REM --- 11) truncamento (STRVAR_LEN=64, 63 chars + nulo) ---
1510 PRINT "TESTE 11: TRUNCAMENTO"
1520 U$ = "XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
1530 PRINT LEN(U$)
1540 PRINT "ESPERADO: 63 (o resto foi cortado)"
1550 PRINT ""

1600 REM --- 12) INPUT de string (interativo - digite e ENTER) ---
1610 PRINT "TESTE 12: INPUT - digite seu nome"
1620 INPUT S$
1630 PRINT "OLA, " + S$ + "!"
1640 PRINT "CONFIRA SE MAIUSC/MINUSC BATEU"
1650 PRINT ""

1700 PRINT "FIM DOS TESTES"